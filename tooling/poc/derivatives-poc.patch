+    new_test_ext(1).execute_with(|| {
+        let netuid = setup_market(1_000_000 * TAO, 1_000_000 * TAO, 1.0);
+        skew_pool(netuid, 0.5, 2_000); // r=0.5 AND ~3% swap fee (2000/65535)
+        let trader = U256::from(10);
+        add_balance_to_coldkey_account(&trader, t(2_000_000 * TAO));
+        let bal0 = bal(&trader);
+        assert_ok!(SubtensorModule::open_short(RuntimeOrigin::signed(trader), U256::from(11), netuid, t(1_000 * TAO), None));
+        assert_ok!(SubtensorModule::do_close_short_self(RuntimeOrigin::signed(trader), netuid, 1_000_000_000, None));
+        let delta = bal(&trader) as i128 - bal0 as i128;
+        println!("[POC-FEE] r=0.5, ~3% fee: trader delta = {delta} rao ({:.2} TAO)", delta as f64 / 1e9);
+        assert!(delta <= TAO as i128, "leak persists net of ~3% swap fee: trader extracted {delta} rao");
+    });
+}
