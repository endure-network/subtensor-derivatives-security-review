+fn poc_emission_drift_then_leak() {
+    new_test_ext(1).execute_with(|| {
+        let netuid = setup_market(1_000_000 * TAO, 1_000_000 * TAO, 1.0);
+        skew_pool(netuid, 1.0, 0); // start EXACTLY 0.5/0.5 (no leak at baseline)
+        let sa = SubtensorModule::get_subnet_account_id(netuid).unwrap();
+        // Per-block protocol emission injection, TAO-heavy (injection ratio != reserve ratio) to
+        // drive w_quote > 0.5 i.e. w1/w2 < 1 (the SHORT-leak side). Alpha-heavy drift gives w1/w2 > 1
+        // (the LONG-leak side) — either drift direction leaves one side exploitable.
+        for _ in 0..60 {
+            let (dt, da) = <Test as pallet::Config>::SwapInterface::adjust_protocol_liquidity(
+                netuid.into(), t(25_000 * TAO), AlphaBalance::from(5_000 * TAO));
+            SubnetTAO::<Test>::mutate(netuid, |x| *x = x.saturating_add(dt));
+            SubnetAlphaIn::<Test>::mutate(netuid, |x| *x = x.saturating_add(da));
+            add_balance_to_coldkey_account(&sa, dt);
+        }
+        let w_quote = pallet_subtensor_swap::SwapBalancer::<Test>::get(netuid).get_quote_weight().deconstruct() as f64 / 1e18;
+        println!("[POC-DRIFT] after 60 emission injections: w_quote = {:.4} (w1/w2 = {:.4})", w_quote, (1.0 - w_quote) / w_quote);
+        assert!((w_quote - 0.5).abs() > 0.02, "drift did not move weights enough: w_quote={w_quote}");
+        SubnetAlphaInMovingReserve::<Test>::insert(netuid, U64F64::from_num(SubnetAlphaIn::<Test>::get(netuid).to_u64()));
+        let trader = U256::from(10);
+        let hot = U256::from(11);
+        add_balance_to_coldkey_account(&trader, t(5_000_000 * TAO));
+        let bal0 = bal(&trader);
+        assert_ok!(SubtensorModule::open_short(RuntimeOrigin::signed(trader), hot, netuid, t(50_000 * TAO), None));
+        assert_ok!(SubtensorModule::do_close_short_self(RuntimeOrigin::signed(trader), netuid, 1_000_000_000, None));
+        let delta = bal(&trader) as i128 - bal0 as i128;
+        println!("[POC-DRIFT] exploit after NATURAL emission drift: trader delta = {delta} rao ({:.2} TAO)", delta as f64 / 1e9);
+        assert!(delta <= TAO as i128, "leak after emission-driven drift (no skew_pool): trader extracted {delta} rao");
+    });
+}
