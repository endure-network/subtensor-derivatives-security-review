+// CONTROL: the SAME open+self-close flow at exactly 0.5/0.5 weights must NOT leak.
+// Proves the leak is caused by the weight skew, not by the flow itself / a test artifact.
+#[test]
+fn poc_baseline_no_skew_no_leak() {
+    new_test_ext(1).execute_with(|| {
+        let netuid = setup_market(1_000_000 * TAO, 1_000_000 * TAO, 1.0);
+        skew_pool(netuid, 1.0, 0); // price 1.0 + equal reserves => weights exactly 0.5/0.5 (r=1)
+        let trader = U256::from(10);
+        add_balance_to_coldkey_account(&trader, t(2_000_000 * TAO));
+        let bal0 = bal(&trader);
+        assert_ok!(SubtensorModule::open_short(RuntimeOrigin::signed(trader), U256::from(11), netuid, t(1_000 * TAO), None));
+        assert_ok!(SubtensorModule::do_close_short_self(RuntimeOrigin::signed(trader), netuid, 1_000_000_000, None));
+        let delta = bal(&trader) as i128 - bal0 as i128;
+        println!("[POC-BASELINE] r=1.0 control: trader delta = {delta} rao ({:.6} TAO)", delta as f64 / 1e9);
+        assert!(delta.abs() <= TAO as i128, "control failed: 0.5/0.5 round-trip leaked {delta} rao (expected ~0)");
+    });
+}
