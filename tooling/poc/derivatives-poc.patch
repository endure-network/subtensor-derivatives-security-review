+// The coarse sweep shows pump_loss/short_leg shrinks as the pump shrinks. AMM
+// round-trip slippage is second-order in trade size while the extracted gap is
+// first-order, so a SMALL pump is the attacker's best shot — this fine sweep
+// hunts that regime for the ratio crossing below 1.0 (a real drain).
+#[test]
+fn poc_cold_ema_cross_state_fine_pump_sweep() {
+    new_test_ext(1).execute_with(|| {
+        let t0 = 100_000 * TAO;
+        let pumps = [100u64, 500, 2_000, 10_000, 50_000];
+        let inputs = [1_000u64, 10_000];
+        let mut idx = 0u32;
+        let mut best: i128 = i128::MIN;
+        let mut best_at = (0u64, 0u64);
+        println!("[FINE]  pump      P  open close       N1       K1  short_leg  pump_loss  ratio       net  [TAO]");
+        for &p in inputs.iter() {
+            for &pump in pumps.iter() {
+                let r = cross_state_short_attack(
+                    idx,
+                    t0,
+                    pump.saturating_mul(TAO),
+                    p.saturating_mul(TAO),
+                    0,
+                    900_000_000,
+                );
+                let ratio = if r.short_leg() > 0 {
+                    r.pump_loss() as f64 / r.short_leg() as f64
+                } else {
+                    f64::NAN
+                };
+                println!(
+                    "[FINE] {:>6} {:>6}  {:>4} {:>4} {:>8.1} {:>8.1} {:>10.1} {:>10.1}  {:>5.3} {:>9.3}",
+                    pump,
+                    p,
+                    r.opened,
+                    r.closed,
+                    r.n1 as f64 / 1e9,
+                    r.k1 as f64 / 1e9,
+                    r.short_leg() as f64 / 1e9,
+                    r.pump_loss() as f64 / 1e9,
+                    ratio,
+                    r.net() as f64 / 1e9
+                );
+                if r.net() > best {
+                    best = r.net();
+                    best_at = (pump, p);
+                }
+                idx = idx.saturating_add(1);
+            }
+        }
+        println!(
+            "[FINE] BEST net = {:.3} TAO at pump={} P={}",
+            best as f64 / 1e9,
+            best_at.0,
+            best_at.1
+        );
+        assert!(
+            best <= i128::from(TAO),
+            "FINE-SWEEP DRAIN: best net {best} rao at pump={} P={}",
+            best_at.0,
+            best_at.1
+        );
+    });
+}
