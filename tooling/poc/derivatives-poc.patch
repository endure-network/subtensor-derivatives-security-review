+        setup_reserves(netuid, t(5000 * TAO), AlphaBalance::from(1000 * TAO));
+        let pumped_cap = SubtensorModule::get_subnet_short_state(netuid).unwrap().footprint_cap.to_u64();
+        println!("[COLD-EMA] honest cap = {} TAO -> pumped cap = {} TAO", honest_cap / TAO, pumped_cap / TAO);
+        assert!(pumped_cap > honest_cap, "cold T_ref must track the live pump");
