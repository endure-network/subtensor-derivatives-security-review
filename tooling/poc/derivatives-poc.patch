+        println!("[XSTATE] T0=A0=100k TAO  fee=0  kappa=0.9  (add_stake pump moves SubnetTAO = T_ref)");
+        println!("[XSTATE]  pump      P  open close  Tbase Tpump Trest       N1       K1  short_leg  pump_loss       net  [TAO]");
+        for &pump in pumps_tao.iter() {
+            for &p in inputs_tao.iter() {
+                let r = cross_state_short_attack(
+                    idx,
+                    t0,
+                    pump.saturating_mul(TAO),
+                    p.saturating_mul(TAO),
+                    0,
+                    900_000_000,
+                );
+                println!(
+                    "[XSTATE] {:>6} {:>6}  {:>4} {:>4}  {:>5} {:>5} {:>5} {:>8.1} {:>8.1} {:>10.1} {:>10.1} {:>9.1}",
+                    pump,
+                    p,
+                    r.opened,
+                    r.closed,
+                    r.t_base / TAO / 1000,
+                    r.t_pumped / TAO / 1000,
+                    r.t_restored / TAO / 1000,
+                    r.n1 as f64 / 1e9,
+                    r.k1 as f64 / 1e9,
+                    r.short_leg() as f64 / 1e9,
+                    r.pump_loss() as f64 / 1e9,
+                    r.net() as f64 / 1e9
+                );
+                if r.net() > worst {
+                    worst = r.net();
+                }
+                idx = idx.saturating_add(1);
+            }
+        }
+        println!(
+            "[XSTATE] WORST-CASE attacker net = {} rao ({:.3} TAO)",
+            worst,
+            worst as f64 / 1e9
+        );
+        // SOUND invariant: cross-state open/close must NOT let the attacker profit
+        // beyond rounding dust. A failure with a large positive `worst` is the
+        // cross-state DRAIN proof (and would escalate F-02 toward HIGH).
+        assert!(
+            worst <= i128::from(TAO),
+            "CROSS-STATE DRAIN: attacker netted {worst} rao ({:.3} TAO) via cold-EMA pumped-open / restored-close",
+            worst as f64 / 1e9
+        );
+    });
+}
