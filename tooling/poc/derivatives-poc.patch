+// in-block-manipulable reserve. The in-block capacity sandwich that `sandwich_open_cannot_breach_
+// capacity_cap` proves IMPOSSIBLE on a warm subnet (T_ref pinned to the lagged A_EMA) SUCCEEDS here.
+#[test]
+fn poc_cold_ema_breaches_capacity_cap() {
+    new_test_ext(1).execute_with(|| {
+        let netuid = add_dynamic_network(&U256::from(2), &U256::from(1));
+        setup_reserves(netuid, t(1500 * TAO), AlphaBalance::from(1000 * TAO));
+        let sa = SubtensorModule::get_subnet_account_id(netuid).unwrap();
+        add_balance_to_coldkey_account(&sa, t(1_000_000 * TAO));
+        SubtensorModule::set_shorts_enabled(true);
+        SubtensorModule::set_short_kappa_ppb(80_000_000); // κ = 0.08
+        assert_eq!(SubtensorModule::get_moving_alpha_price(netuid), 0); // COLD ⇒ T_ref = t_live
+
+        let honest_cap = SubtensorModule::get_subnet_short_state(netuid).unwrap().footprint_cap.to_u64();
+        let p = t(200 * TAO);
+        let trader = U256::from(10);
+        add_balance_to_coldkey_account(&trader, t(2_000_000 * TAO));
