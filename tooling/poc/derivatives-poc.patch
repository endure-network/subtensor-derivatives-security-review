+// SUSTAINED: repeating the round-trip drains the pool proportionally (not a one-off artifact).
+#[test]
+fn poc_repeat_drain() {
+    new_test_ext(1).execute_with(|| {
+        let netuid = setup_market(10_000_000 * TAO, 10_000_000 * TAO, 1.0);
+        skew_pool(netuid, 0.5, 0);
+        let trader = U256::from(10);
+        let hot = U256::from(11);
+        add_balance_to_coldkey_account(&trader, t(5_000_000 * TAO));
+        let pool0 = SubnetTAO::<Test>::get(netuid).to_u64();
+        let bal0 = bal(&trader);
+        for _ in 0..5 {
+            assert_ok!(SubtensorModule::open_short(RuntimeOrigin::signed(trader), hot, netuid, t(1_000 * TAO), None));
+            assert_ok!(SubtensorModule::do_close_short_self(RuntimeOrigin::signed(trader), netuid, 1_000_000_000, None));
+        }
+        let gained = bal(&trader) as i128 - bal0 as i128;
+        let drained = pool0 as i128 - SubnetTAO::<Test>::get(netuid).to_u64() as i128;
+        println!("[POC-REPEAT] 5x round-trip: attacker gained {gained} rao ({:.2} TAO); pool drained {drained} rao", gained as f64 / 1e9);
+        assert!(gained <= TAO as i128, "sustained drain: attacker netted {gained} rao over 5 round-trips with no price move");
+    });
+}
