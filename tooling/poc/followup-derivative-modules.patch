@@ -0,0 +1,81 @@
+#![allow(clippy::arithmetic_side_effects, clippy::unwrap_used)]
+
+use super::mock::*;
+use crate::derivatives::{ShortAgg, ShortPosition};
+use crate::*;
+use sp_core::U256;
+use substrate_fixed::types::{I64F64, I96F32, U64F64};
+use subtensor_runtime_common::{AlphaBalance, NetUid, TaoBalance, Token};
+
+const TAO: u64 = 1_000_000_000;
+
+fn t(v: u64) -> TaoBalance {
+    TaoBalance::from(v)
+}
+
+fn bal(acc: &U256) -> u64 {
+    Balances::free_balance(acc).into()
+}
+
+fn setup_market() -> NetUid {
+    let owner_coldkey = U256::from(1);
+    let owner_hotkey = U256::from(2);
+    let netuid = add_dynamic_network(&owner_hotkey, &owner_coldkey);
+    setup_reserves(netuid, t(10_000 * TAO), AlphaBalance::from(10_000 * TAO));
+    let subnet_account = SubtensorModule::get_subnet_account_id(netuid).unwrap();
+    add_balance_to_coldkey_account(&subnet_account, t(10_000 * TAO));
+    SubnetMovingPrice::<Test>::insert(netuid, I96F32::from_num(0.1));
+    SubnetAlphaInMovingReserve::<Test>::insert(netuid, U64F64::from_num(10_000 * TAO));
+    netuid
+}
+
+#[test]
+fn terminal_settlement_pays_identical_shorts_different_equity() {
+    new_test_ext(1).execute_with(|| {
+        let netuid = setup_market();
+        let first = U256::from(10);
+        let second = U256::from(20);
+        let position = ShortPosition {
+            hotkey: U256::from(30),
+            p_floor: t(1_500 * TAO),
+            q_liability: AlphaBalance::from(1_000 * TAO),
+            r_stored: TaoBalance::ZERO,
+            e_stored: t(500 * TAO),
+            b_stored: TaoBalance::ZERO,
+            omega_entry: I64F64::from_num(0),
+            last_active: 0,
+        };
+
+        ShortPositions::<Test>::insert(netuid, first, position.clone());
+        ShortPositions::<Test>::insert(netuid, second, position);
+        ShortPositionCount::<Test>::insert(netuid, 2);
+        ShortAggregate::<Test>::insert(
+            netuid,
+            ShortAgg {
+                r_sigma: TaoBalance::ZERO,
+                e_sigma: t(1_000 * TAO),
+                b_sigma: TaoBalance::ZERO,
+                q_sigma: AlphaBalance::from(2_000 * TAO),
+                omega: I64F64::from_num(0),
+            },
+        );
+        add_balance_to_coldkey_account(&SubtensorModule::short_custody_account(netuid), t(4_000 * TAO));
+
+        let first_before = bal(&first);
+        let second_before = bal(&second);
+
+        SubtensorModule::settle_shorts_on_dereg(netuid);
+
+        let first_equity = bal(&first) - first_before;
+        let second_equity = bal(&second) - second_before;
+        println!(
+            "[TERMINAL-ORDER] first equity = {first_equity} rao, second equity = {second_equity} rao"
+        );
+        assert!(
+            first_equity.abs_diff(second_equity) > TAO,
+            "identical positions settled too similarly: first={first_equity}, second={second_equity}"
+        );
+        assert!(ShortPositions::<Test>::get(netuid, first).is_none());
+        assert!(ShortPositions::<Test>::get(netuid, second).is_none());
+    });
+}
